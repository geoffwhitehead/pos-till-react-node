platform :ios, '16.0'

require_relative '../node_modules/react-native/scripts/react_native_pods'

target 'Positive' do
  # use_frameworks! :linkage => :static

  # Modern autolinking for React Native dependencies
  use_react_native!(
    :path => '../node_modules/react-native',
    :hermes_enabled => true # Change to false if not using Hermes
  )

  # Third-party dependencies
  # Uncomment this line if you're not using auto-linking or if auto-linking causes trouble
  # pod 'WatermelonDB', path: '../node_modules/@nozbe/watermelondb'

  # WatermelonDB dependency, should not be needed on modern React Native
  # (please file an issue if this causes issues for you)
  # pod 'React-jsi', path: '../node_modules/react-native/ReactCommon/jsi', modular_headers: true

  # WatermelonDB dependency
  pod 'simdjson', path: '../node_modules/@nozbe/simdjson', modular_headers: true
  pod 'RNVectorIcons', :path => '../node_modules/react-native-vector-icons'
  pod 'RNStarPrnt', :path => '../node_modules/react-native-star-prnt'
  pod 'RNSVG', :path => '../node_modules/react-native-svg'
end

post_install do |installer|
  # Optionally clean up any specific build settings or add additional tweaks
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = "arm64" # Prevent architecture issues on M1 Macs
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end
  end
end